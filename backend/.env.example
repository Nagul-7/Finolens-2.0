# ─── Database ───────────────────────────────────────────────────────────────
DATABASE_URL=postgres://finolens:finolens_dev@localhost:5432/finolens_db
POSTGRES_PASSWORD=finolens_dev

# ─── Redis ──────────────────────────────────────────────────────────────────
REDIS_URL=redis://:redis_dev@localhost:6379
